{
  "name": "@tinytinkerer/host",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "tinytinkerer": {
    "architectureRole": "host-compositor"
  },
  "scripts": {
    "dev": "node ./src/host-server.mjs",
    "build": "if [ -z \"$TINYTINKERER_SKIP_BRAND_ASSET_GENERATION\" ]; then pnpm -w generate:brand-assets; fi && vite build && node ./src/build-pages.mjs",
    "lint": "eslint src",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tinytinkerer/app-browser": "workspace:*",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "vite": "8.0.14"
  },
  "devDependencies": {
    "@sentry/vite-plugin": "5.3.0",
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "jsdom": "29.1.1",
    "tailwindcss": "4.3.0",
    "vite-plugin-pwa": "1.3.0"
  }
}
