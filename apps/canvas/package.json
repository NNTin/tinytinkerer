{
  "name": "@tinytinkerer/canvas",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "tinytinkerer": {
    "architectureRole": "harness-shell",
    "protocolPackage": "@tinytinkerer/excalidraw-protocol",
    "iframeAppPackage": "@tinytinkerer/excalidraw-app",
    "iframeEntry": "excalidraw-app/main.tsx"
  },
  "scripts": {
    "dev": "if [ -z \"$TINYTINKERER_SKIP_BRAND_ASSET_GENERATION\" ]; then pnpm -w generate:brand-assets; fi && vite",
    "build": "if [ -z \"$TINYTINKERER_SKIP_BRAND_ASSET_GENERATION\" ]; then pnpm -w generate:brand-assets; fi && vite build && vite build --config vite.excalidraw.config.ts && vite build --config vite.callback.config.ts",
    "lint": "eslint src excalidraw-app library-callback",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tinytinkerer/app-browser": "workspace:*",
    "@tinytinkerer/app-harness": "workspace:*",
    "@tinytinkerer/excalidraw-app": "workspace:*",
    "@tinytinkerer/excalidraw-protocol": "workspace:*",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router-dom": "7.16.0"
  },
  "devDependencies": {
    "@sentry/vite-plugin": "5.3.0",
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/jest-dom": "6.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "jsdom": "29.1.1",
    "tailwindcss": "4.3.0",
    "vite": "8.0.14",
    "vite-plugin-pwa": "1.3.0"
  }
}
