                  "$ref": "#/components/schemas/EdgeErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "Bad gateway",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EdgeErrorResponse"
                }
              }
            }
