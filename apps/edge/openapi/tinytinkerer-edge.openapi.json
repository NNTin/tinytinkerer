        "responses": {
          "200": {
            "description": "Chat completion (JSON) or Server-Sent Events stream",
            "headers": {
              "x-ratelimit-limit-requests": {
                "$ref": "#/components/headers/x-ratelimit-limit-requests"
              },
              "x-ratelimit-remaining-requests": {
                "$ref": "#/components/headers/x-ratelimit-remaining-requests"
              },
              "x-ratelimit-reset-requests": {
                "$ref": "#/components/headers/x-ratelimit-reset-requests"
              },
              "x-ratelimit-renewalperiod-requests": {
                "$ref": "#/components/headers/x-ratelimit-renewalperiod-requests"
              },
              "x-ratelimit-limit-tokens": {
                "$ref": "#/components/headers/x-ratelimit-limit-tokens"
              },
              "x-ratelimit-remaining-tokens": {
                "$ref": "#/components/headers/x-ratelimit-remaining-tokens"
              },
              "x-ratelimit-reset-tokens": {
                "$ref": "#/components/headers/x-ratelimit-reset-tokens"
              },
              "x-ratelimit-renewalperiod-tokens": {
                "$ref": "#/components/headers/x-ratelimit-renewalperiod-tokens"
              },
              "x-ratelimit-abusepenalty-active": {
                "$ref": "#/components/headers/x-ratelimit-abusepenalty-active"
              }
            },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ModelsChatResponse" }
              },
              "text/event-stream": {
                "schema": { "type": "string" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Error" },
          "401": { "$ref": "#/components/responses/Error" },
          "403": { "$ref": "#/components/responses/Error" },
          "422": { "$ref": "#/components/responses/Error" },
          "429": { "$ref": "#/components/responses/RateLimit" },
          "500": { "$ref": "#/components/responses/Error" },
          "502": { "$ref": "#/components/responses/Error" },
          "503": { "$ref": "#/components/responses/Error" },
          "504": { "$ref": "#/components/responses/Error" }
        }
      },
      "options": {
        "operationId": "preflightModelsChat",
        "summary": "CORS preflight",
        "security": [],
        "parameters": [
          { "$ref": "#/components/parameters/OriginHeader" },
          { "$ref": "#/components/parameters/AccessControlRequestMethodHeader" },
          { "$ref": "#/components/parameters/AccessControlRequestHeadersHeader" }
        ],
        "responses": {
          "204": { "$ref": "#/components/responses/Preflight" }
        }
      }
    },
