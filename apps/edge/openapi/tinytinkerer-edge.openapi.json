            "in": "header"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "X-Build-Hash",
            "in": "header"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "X-Install-ID",
            "in": "header"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "X-GitHub-ID",
