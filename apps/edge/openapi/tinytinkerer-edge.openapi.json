      "x-route-key": "search",
      "post": {
        "operationId": "createSearch",
        "summary": "Proxy a Tavily web search",
        "parameters": [
          { "$ref": "#/components/parameters/AppVersionHeader" },
          { "$ref": "#/components/parameters/BuildHashHeader" },
          { "$ref": "#/components/parameters/InstallIdHeader" },
