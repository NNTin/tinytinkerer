          { "$ref": "#/components/parameters/OriginHeader" },
          { "$ref": "#/components/parameters/AccessControlRequestMethodHeader" },
          { "$ref": "#/components/parameters/AccessControlRequestHeadersHeader" }
        ],
        "responses": {
          "204": { "$ref": "#/components/responses/Preflight" }
        }
      }
    },
    "/api/models/chat": {
      "x-route-key": "modelsChat",
      "post": {
        "operationId": "createModelsChat",
        "summary": "Proxy a GitHub Models chat completion",
        "parameters": [
          { "$ref": "#/components/parameters/AppVersionHeader" },
          { "$ref": "#/components/parameters/BuildHashHeader" },
          { "$ref": "#/components/parameters/InstallIdHeader" },
          { "$ref": "#/components/parameters/GitHubIdHeader" }
