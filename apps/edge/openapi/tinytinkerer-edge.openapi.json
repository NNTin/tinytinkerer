          "200": {
            "description": "Service status",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SystemStatus" }
              }
            }
          }
        }
      },
      "options": {
        "operationId": "preflightHealth",
        "summary": "CORS preflight",
        "security": [],
        "parameters": [
          { "$ref": "#/components/parameters/OriginHeader" },
          { "$ref": "#/components/parameters/AccessControlRequestMethodHeader" },
          { "$ref": "#/components/parameters/AccessControlRequestHeadersHeader" }
        ],
        "responses": {
          "204": { "$ref": "#/components/responses/Preflight" }
        }
      }
    },
    "/auth/github/exchange": {
      "x-route-key": "authGithubExchange",
      "post": {
        "operationId": "exchangeGitHubCode",
        "summary": "Exchange a GitHub OAuth code for an access token",
        "parameters": [
          { "$ref": "#/components/parameters/AppVersionHeader" },
          { "$ref": "#/components/parameters/BuildHashHeader" },
          { "$ref": "#/components/parameters/InstallIdHeader" },
          { "$ref": "#/components/parameters/GitHubIdHeader" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/GitHubExchangeRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token or error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GitHubExchangeResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid code or failed exchange",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GitHubExchangeResponse"
                }
              }
            }
          },
          "501": {
            "description": "OAuth not configured",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GitHubExchangeResponse"
                }
              }
            }
          }
        }
      },
      "options": {
        "operationId": "preflightAuthGitHubExchange",
        "summary": "CORS preflight",
        "security": [],
        "parameters": [
          { "$ref": "#/components/parameters/OriginHeader" },
          { "$ref": "#/components/parameters/AccessControlRequestMethodHeader" },
          { "$ref": "#/components/parameters/AccessControlRequestHeadersHeader" }
        ],
        "responses": {
          "204": { "$ref": "#/components/responses/Preflight" }
        }
      }
    },
