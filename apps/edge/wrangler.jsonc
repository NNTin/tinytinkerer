{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "tinytinkerer-edge",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-21",
  // nodejs_compat is required by the @sentry/cloudflare SDK (AsyncLocalStorage).
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,
  // Emit source maps when bundling (`wrangler deploy --dry-run --outdir dist`)
  // so debug IDs can be injected and the maps uploaded to Sentry (see the
  // bundle/inject/deploy steps in .github/workflows/deploy-edge.yml).
  "upload_source_maps": true,
  "routes": [
    {
      "pattern": "api.tiny.nntin.xyz",
      "custom_domain": true
    }
  ],
  // Production only serves the production frontend. PR previews now reuse the
  // develop edge (see env.develop), so the preview wildcard is intentionally
  // absent here.
  "vars": {
    "ALLOWED_ORIGINS": "http://localhost:3111,https://tiny.nntin.xyz",
    "LITELLM_BASE_URL": "https://litellm.labs.lair.nntin.xyz/",
    "LITELLM_ALLOWED_BASE_URLS": "https://litellm.labs.lair.nntin.xyz/",
    "LITELLM_USER_MAX_BUDGET_USD": "1",
    "LITELLM_USER_BUDGET_DURATION": "30d",
    "LITELLM_USER_RPM_LIMIT": "10",
    "LITELLM_USER_TPM_LIMIT": "100000",
    "SENTRY_ENVIRONMENT": "production"
  },
  // The develop edge backs both the develop frontend (dev.tiny.nntin.xyz) and
  // every PR preview (*.tiny.preview.nntin.xyz), so experimental edge work can
  // ship without touching production. Deployed with `wrangler deploy --env
  // develop` from .github/workflows/deploy-edge.yml on pushes to `develop`.
  // `vars` and `routes` are NOT inherited from the top-level config — wrangler
  // replaces them per environment, so both are redeclared here in full. The
  // inheritable keys (main, compatibility_*, upload_source_maps, workers_dev)
  // do carry over and are intentionally not repeated.
  "env": {
    "develop": {
      "name": "tinytinkerer-edge-develop",
      "routes": [
        {
          "pattern": "api.dev.tiny.nntin.xyz",
          "custom_domain": true
        }
      ],
      "vars": {
        "ALLOWED_ORIGINS": "http://localhost:3111,https://dev.tiny.nntin.xyz,https://*.tiny.preview.nntin.xyz",
        "LITELLM_BASE_URL": "https://litellm.labs.lair.nntin.xyz/",
        "LITELLM_ALLOWED_BASE_URLS": "https://litellm.labs.lair.nntin.xyz/",
        "LITELLM_USER_MAX_BUDGET_USD": "1",
        "LITELLM_USER_BUDGET_DURATION": "30d",
        "LITELLM_USER_RPM_LIMIT": "10",
        "LITELLM_USER_TPM_LIMIT": "100000",
        "SENTRY_ENVIRONMENT": "develop"
      }
    }
  }
  // Required secrets (set via `wrangler secret put`): GITHUB_CLIENT_ID, GITHUB_CLIENT_SECRET,
  // LITELLM_KEY_MANAGEMENT_API_KEY, LITELLM_USER_KEY_SECRET.
  // LITELLM_BASE_URL (vars above) is required too: the edge has no code-level
  // fallback, and a deployment without it serves 503 "LiteLLM is not configured."
  // — forks must point the var at their own LiteLLM deployment.
  // Optional secret: SENTRY_DSN. SENTRY_RELEASE is set at deploy time from the git SHA.
  //
  // Optional vars (sensible code-level defaults apply when unset):
  // - MCP_ALLOWED_HOSTS: comma-separated hostnames the MCP proxy may connect to
  //   (e.g. "mcp.example.com,localhost"). Unset/empty keeps the built-in
  //   private-address blocklist (which DNS rebinding can bypass — see
  //   src/routes/mcp.ts); when set, ONLY the listed hosts are reachable.
  // - RATE_LIMIT_WINDOW_SECONDS: inbound rate-limit window (default 60).
  // - RATE_LIMIT_AUTH_MAX / RATE_LIMIT_SEARCH_MAX / RATE_LIMIT_MCP_MAX: max
  //   requests per caller per window for the OAuth exchange (default 10),
  //   search (default 30), and MCP (default 60) routes; "0" disables that
  //   scope's limit. See src/lib/inbound-rate-limit.ts.
  // - GITHUB_ALLOWED_USERS: comma-separated GitHub ids or logins allowed to use
  //   model/search/MCP proxy routes. Unset allows any valid GitHub token.
  // - LITELLM_USER_MODELS: comma-separated LiteLLM model aliases assigned to
  //   generated per-user keys. Unset/empty lets keys call all configured models.
}
