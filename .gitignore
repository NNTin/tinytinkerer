node_modules
.pnpm-store
.turbo
dist
# The root composition app (apps/host) builds here before build-pages composes it
# into apps/host/dist alongside the /<slug>/ shells. Build artifact, never versioned.
dist-root
coverage
# Allure test-report inputs/outputs (issue #254): per-package raw results from the
# allure-vitest/allure-playwright reporters, the consolidated vitest results, and the
# generated HTML report. All derived in CI for PR previews — never versioned.
allure-results
allure-results-vitest
allure-report
test-report
**/generated/
**/*.generated.ts
# Exception: the edge contracts are generated from the OpenAPI source but the
# contracts package has no build step (it is consumed directly from src/), so the
# generated module is committed and kept fresh in CI via `pnpm check:edge-openapi`.
!packages/shared/contracts/src/edge.generated.ts
.env
.env.*
!.env.example
apps/web/node_modules
apps/web/dist
apps/web/pnpm-lock.yaml
apps/edge/.wrangler
apps/edge/.dev.vars
.claude/
agent-orchestrator.yaml
apps/mobile/dev-dist/
.vercel/
.vercel
.env*

# Agent Orchestrator runtime data
.ao/

# Compliance artifacts — generated on demand by the Compliance workflow
# (scripts/generate-sbom.mjs / generate-notices.mjs) into dist/compliance/.
# Not versioned: they are derived from the dependency tree and shipped as CI
# artifacts, not source. Already covered by the `dist` rule above; listed
# explicitly so the artifact location stays documented.
dist/compliance/
