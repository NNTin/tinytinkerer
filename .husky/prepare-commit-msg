#!/usr/bin/env sh

COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2

rewrite_revert_message() {
  FIRST_LINE=$(sed -n '1p' "$COMMIT_MSG_FILE")
  ORIGINAL_SUBJECT=$(printf '%s\n' "$FIRST_LINE" | sed -n 's/^Revert "\([^"]*\)"$/\1/p')

  if [ -z "$ORIGINAL_SUBJECT" ]; then
    return 1
  fi

  REVERTED_COMMIT=$(
    sed -n 's/^This reverts commit \([0-9a-fA-F]\{40\}\)\.$/\1/p' "$COMMIT_MSG_FILE" |
      sed -n '1p'
  )

  if [ -z "$REVERTED_COMMIT" ]; then
    return 1
  fi

  ORIGINAL_SCOPE=$(printf '%s\n' "$ORIGINAL_SUBJECT" | sed -E -n 's/^[a-z][a-z0-9-]*(\(([^)]+)\))?(!)?: .+$/\2/p')
  ORIGINAL_DESCRIPTION=$(printf '%s\n' "$ORIGINAL_SUBJECT" | sed -E -n 's/^[a-z][a-z0-9-]*(\([^)]+\))?(!)?: (.+)$/\3/p')

  if [ -z "$ORIGINAL_DESCRIPTION" ]; then
    ORIGINAL_DESCRIPTION=$ORIGINAL_SUBJECT
  fi

  if [ -n "$ORIGINAL_SCOPE" ]; then
    REVERT_MESSAGE="revert($ORIGINAL_SCOPE): $ORIGINAL_DESCRIPTION"
  else
    REVERT_MESSAGE="revert: $ORIGINAL_DESCRIPTION"
  fi

  TMP_FILE=$(mktemp)

  {
    printf '%s\n' "$REVERT_MESSAGE"
    sed '1d' "$COMMIT_MSG_FILE"
  } > "$TMP_FILE"

  cat "$TMP_FILE" > "$COMMIT_MSG_FILE"
  rm -f "$TMP_FILE"

  return 0
}

rewrite_merge_message() {
  FIRST_LINE=$(sed -n '1p' "$COMMIT_MSG_FILE")
  case "$FIRST_LINE" in
    Merge\ *)
      ;;
    *)
      return 1
      ;;
  esac

  MERGE_HEAD_FILE=$(git rev-parse --git-path MERGE_HEAD 2>/dev/null)
  MERGED_COMMIT=""

  if [ -n "$MERGE_HEAD_FILE" ] && [ -f "$MERGE_HEAD_FILE" ]; then
    MERGED_COMMIT=$(sed -n '1p' "$MERGE_HEAD_FILE" | xargs git rev-parse 2>/dev/null)
  fi

  if [ -z "$MERGED_COMMIT" ]; then
    MERGED_COMMIT=$(printf '%s\n' "$FIRST_LINE" | sed -n "s/^Merge commit '\([0-9a-fA-F]\{40\}\)'.*/\1/p")
  fi

  if [ -z "$MERGED_COMMIT" ]; then
    MERGED_COMMIT="unknown"
  fi

  TARGET_COMMIT=$(git rev-parse HEAD 2>/dev/null || printf '%s' "unknown")
  MERGE_MESSAGE="chore(merge): merge $MERGED_COMMIT into $TARGET_COMMIT"
  TMP_FILE=$(mktemp)

  {
    printf '%s\n' "$MERGE_MESSAGE"
    sed '1d' "$COMMIT_MSG_FILE"
  } > "$TMP_FILE"

  cat "$TMP_FILE" > "$COMMIT_MSG_FILE"
  rm -f "$TMP_FILE"

  return 0
}

is_merge_commit_context() {
  if [ "$COMMIT_SOURCE" = "merge" ]; then
    return 0
  fi

  MERGE_HEAD_FILE=$(git rev-parse --git-path MERGE_HEAD 2>/dev/null)
  [ -n "$MERGE_HEAD_FILE" ] && [ -f "$MERGE_HEAD_FILE" ]
}

if rewrite_revert_message; then
  exit 0
fi

if is_merge_commit_context; then
  rewrite_merge_message
fi

exit 0
