{
  "name": "@tinytinkerer/app-browser",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "./src/styles.css"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./styles.css": "./src/styles.css"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "pnpm -w generate:privacy-policy && tsc -p tsconfig.json",
    "lint": "eslint src tests",
    "test": "pnpm -w generate:privacy-policy && vitest run --passWithNoTests",
    "typecheck": "pnpm -w generate:privacy-policy && tsc -p tsconfig.json"
  },
  "dependencies": {
    "@sentry/react": "10.55.0",
    "@tanstack/react-query": "5.100.14",
    "@tinytinkerer/app-core": "workspace:*",
    "@tinytinkerer/brand-assets": "workspace:*",
    "@tinytinkerer/content-callout": "workspace:*",
    "@tinytinkerer/content-code": "workspace:*",
    "@tinytinkerer/content-image": "workspace:*",
    "@tinytinkerer/content-link-card": "workspace:*",
    "@tinytinkerer/content-markdown": "workspace:*",
    "@tinytinkerer/content-mermaid": "workspace:*",
    "@tinytinkerer/content-react": "workspace:*",
    "@tinytinkerer/content-table": "workspace:*",
    "@tinytinkerer/content-wireframe": "workspace:*",
    "@tinytinkerer/contracts": "workspace:*",
    "@tinytinkerer/sentry-telemetry": "workspace:*",
    "dexie": "4.4.3",
    "react-icons": "5.6.0",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "jsdom": "29.1.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router-dom": "7.16.0",
    "vite": "8.0.14",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.7"
  }
}
