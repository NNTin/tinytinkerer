{
  "name": "@tinytinkerer/app-browser",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "./src/styles.css"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./browser-settings-modal": {
      "types": "./src/browser-settings-modal.tsx",
      "default": "./src/browser-settings-modal.tsx"
    },
    "./styles.css": "./src/styles.css"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src tests",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@tinytinkerer/app-core": "workspace:*",
    "@tinytinkerer/brand-assets": "workspace:*",
    "@tinytinkerer/content-callout": "workspace:*",
    "@tinytinkerer/content-code": "workspace:*",
    "@tinytinkerer/content-image": "workspace:*",
    "@tinytinkerer/content-link-card": "workspace:*",
    "@tinytinkerer/content-markdown": "workspace:*",
    "@tinytinkerer/content-mermaid": "workspace:*",
    "@tinytinkerer/content-react": "workspace:*",
    "@tinytinkerer/content-table": "workspace:*",
    "@tinytinkerer/content-wireframe": "workspace:*",
    "@tinytinkerer/contracts": "workspace:*",
    "dexie": "^4.2.1",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.1.1",
    "react": "^19.0.0",
    "react-router-dom": "^7.9.5",
    "vite": "^8.0.12",
    "vitest": "^4.0.8"
  }
}
