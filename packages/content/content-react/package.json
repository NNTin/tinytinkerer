{
  "name": "@tinytinkerer/content-react",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "./src/styles.css"
  ],
  "exports": {
    ".": {
      "types": "./src/index.tsx",
      "default": "./src/index.tsx"
    },
    "./styles.css": "./src/styles.css"
  },
  "main": "src/index.tsx",
  "types": "src/index.tsx",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src tests",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@tinytinkerer/content-core": "workspace:*",
    "@tinytinkerer/ui": "workspace:*",
    "dompurify": "3.4.11"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "jsdom": "29.1.1",
    "react": "19.2.6",
    "vite": "8.0.14",
    "vitest": "4.1.7"
  }
}
