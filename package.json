{
  "name": "tinytinkerer",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "generate:brand-assets": "node ./scripts/generate-brand-assets.mjs",
    "dev": "pnpm generate:brand-assets && TINYTINKERER_SKIP_BRAND_ASSET_GENERATION=1 turbo run dev --parallel",
    "build": "pnpm generate:brand-assets && TINYTINKERER_SKIP_BRAND_ASSET_GENERATION=1 turbo run build",
    "check:boundaries": "node ./scripts/check-boundaries.mjs",
    "check:mermaid": "node ./scripts/check-mermaid.mjs",
    "lint": "turbo run lint && node ./scripts/check-boundaries.mjs",
    "test": "pnpm generate:brand-assets && turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.4",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "png-to-ico": "3.0.1",
    "prettier": "^3.6.2",
    "sharp": "0.34.5",
    "turbo": "^2.5.8",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.0.8"
  }
}
