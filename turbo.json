{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "env": [
        "TINYTINKERER_SKIP_BRAND_ASSET_GENERATION",
        "TINYTINKERER_DEPLOY_BASE",
        "TINYTINKERER_TEST_REPORT_DIR",
        "GIT_SHA",
        "VITE_EDGE_URL",
        "VITE_SENTRY_DSN",
        "VITE_SENTRY_ENVIRONMENT",
        "SENTRY_AUTH_TOKEN"
      ]
    },
    "@tinytinkerer/host#build": {
      "dependsOn": [
        "@tinytinkerer/web#build",
        "@tinytinkerer/widget#build",
        "@tinytinkerer/mobile#build",
        "@tinytinkerer/canvas#build",
        "@tinytinkerer/excalidraw-app#build"
      ],
      "outputs": ["dist/**"],
      "env": [
        "TINYTINKERER_SKIP_BRAND_ASSET_GENERATION",
        "TINYTINKERER_DEPLOY_BASE",
        "TINYTINKERER_TEST_REPORT_DIR",
        "GIT_SHA",
        "VITE_EDGE_URL",
        "VITE_SENTRY_DSN",
        "VITE_SENTRY_ENVIRONMENT",
        "SENTRY_AUTH_TOKEN"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "TINYTINKERER_SKIP_BRAND_ASSET_GENERATION",
        "TINYTINKERER_DEPLOY_BASE",
        "GIT_SHA",
        "VITE_EDGE_URL",
        "VITE_SENTRY_DSN",
        "VITE_SENTRY_ENVIRONMENT",
        "SENTRY_AUTH_TOKEN"
      ]
    },
    "lint": {},
    "test": {
      "outputs": ["coverage/**"]
    },
    "typecheck": {}
  }
}
