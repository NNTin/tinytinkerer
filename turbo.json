{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "TINYTINKERER_SKIP_BRAND_ASSET_GENERATION",
    "TINYTINKERER_DEPLOY_BASE",
    "GIT_SHA",
    "VITE_SENTRY_DSN"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@tinytinkerer/host#build": {
      "dependsOn": [
        "@tinytinkerer/web#build",
        "@tinytinkerer/widget#build",
        "@tinytinkerer/mobile#build"
      ],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "test": {
      "outputs": ["coverage/**"]
    },
    "typecheck": {}
  }
}
