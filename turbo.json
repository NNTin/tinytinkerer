{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["TINYTINKERER_SKIP_BRAND_ASSET_GENERATION", "TINYTINKERER_DEPLOY_BASE"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "test": {
      "outputs": ["coverage/**"]
    },
    "typecheck": {}
  }
}
